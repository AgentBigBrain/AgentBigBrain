# AgentBigBrain - Environment Configuration Template
# Copy to .env and replace placeholder values before running provider-backed features.
#
# PowerShell:
#   Copy-Item .env.example .env
# Bash:
#   cp .env.example .env

# Model backend
BRAIN_MODEL_BACKEND=mock

# Ollama local model routing (required only when BRAIN_MODEL_BACKEND=ollama)
# Set OLLAMA_MODEL_DEFAULT or the alias-specific variables below so planner aliases resolve to a
# concrete local model tag.
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_TIMEOUT_MS=60000
# OLLAMA_MODEL_DEFAULT=gemma4:latest
# OLLAMA_MODEL_SMALL_FAST=gemma4:latest
# OLLAMA_MODEL_SMALL_POLICY=gemma4:latest
# OLLAMA_MODEL_MEDIUM_GENERAL=gemma4:latest
# OLLAMA_MODEL_MEDIUM_POLICY=gemma4:latest
# OLLAMA_MODEL_LARGE_REASONING=gemma4:latest

# OpenAI API credentials and connection (required only when BRAIN_MODEL_BACKEND=openai_api)
OPENAI_API_KEY=<REPLACE_WITH_OPENAI_API_KEY>
# OPENAI_BASE_URL=
OPENAI_TIMEOUT_MS=300000
# Transport selection: auto chooses the preferred OpenAI transport for the resolved model family.
# Supported values: auto, chat_completions, responses
OPENAI_TRANSPORT_MODE=auto
# Strict=false allows lowest-common-denominator compatibility behavior for unknown model ids.
OPENAI_COMPATIBILITY_STRICT=false
# Optional one-step compatibility fallback from strict schema mode to json_object mode.
OPENAI_ALLOW_JSON_OBJECT_COMPAT_FALLBACK=false

# OpenAI API model routing
OPENAI_MODEL_SMALL_FAST=gpt-4.1-mini
OPENAI_MODEL_SMALL_POLICY=gpt-4.1-mini
OPENAI_MODEL_MEDIUM_GENERAL=gpt-4.1
OPENAI_MODEL_MEDIUM_POLICY=gpt-4.1-mini
OPENAI_MODEL_LARGE_REASONING=gpt-5.3-codex

# Codex OAuth backend (required only when BRAIN_MODEL_BACKEND=codex_oauth)
# Login is managed through: npm run dev -- auth codex login
# CODEX_AUTH_STATE_DIR=
# CODEX_CLI_PATH=
# CODEX_TIMEOUT_MS=180000
# CODEX_MODEL_SMALL_FAST=gpt-5.4-mini
# CODEX_MODEL_SMALL_POLICY=gpt-5.4-mini
# CODEX_MODEL_MEDIUM_GENERAL=gpt-5.4-mini
# CODEX_MODEL_MEDIUM_POLICY=gpt-5.4-mini
# CODEX_MODEL_LARGE_REASONING=gpt-5.4

# Media understanding
# Screenshots use a vision-capable model when available.
# Voice notes use either a dedicated transcription model (for example whisper-1) or a multimodal
# audio-capable chat model (for example Gemma 4 through Ollama's local compatibility endpoint).
# Short video is accepted as input, but today it stays on simple metadata/caption fallback.
# By default, media inherits the main text backend. You can keep one global media backend, or split
# vision and transcription by modality. For example: keep screenshots on codex_oauth while forcing
# voice-note transcription onto the explicit API-key path.
# BRAIN_MEDIA_BACKEND=inherit_text_backend
# BRAIN_MEDIA_VISION_BACKEND=inherit_text_backend
# BRAIN_MEDIA_TRANSCRIPTION_BACKEND=inherit_text_backend
# Example local Gemma 4 image path:
# BRAIN_MEDIA_VISION_BACKEND=ollama
# BRAIN_MEDIA_VISION_MODEL=gemma4:latest
# Experimental local Gemma 4 audio path through Ollama:
# This depends on Ollama exposing working audio input for the selected Gemma build.
# We are monitoring Ollama for native local audio support before recommending this as the default.
# BRAIN_MEDIA_TRANSCRIPTION_BACKEND=ollama
# BRAIN_MEDIA_TRANSCRIPTION_MODEL=gemma4:latest
BRAIN_MEDIA_VISION_MODEL=gpt-5.4-mini
BRAIN_MEDIA_TRANSCRIPTION_MODEL=whisper-1
BRAIN_MEDIA_REQUEST_TIMEOUT_MS=45000

# OpenAI token pricing (USD per 1M tokens, for spend estimates)
OPENAI_PRICE_INPUT_PER_1M_USD=0.15
OPENAI_PRICE_OUTPUT_PER_1M_USD=0.60

# Runtime mode and safety latches
BRAIN_RUNTIME_MODE=isolated
BRAIN_ALLOW_FULL_ACCESS=false
BRAIN_ENABLE_REAL_SHELL=false
BRAIN_ENABLE_REAL_NETWORK_WRITE=false
BRAIN_ALLOW_DAEMON_MODE=false
# Browser verification launches headless by default. Set visible=true to watch Chromium locally.
BRAIN_BROWSER_VERIFY_VISIBLE=false
# Optional alias for the same behavior. Leave unset unless you prefer explicit headless control.
# BRAIN_BROWSER_VERIFY_HEADLESS=true

# Budget controls
BRAIN_MAX_ACTION_COST_USD=1.25
BRAIN_MAX_CUMULATIVE_COST_USD=10
BRAIN_MAX_MODEL_SPEND_USD=10
# Applies to non-API backends such as codex_oauth and ollama.
BRAIN_MAX_NON_API_MODEL_CALLS_PER_TASK=250
BRAIN_MAX_SUBAGENTS_PER_TASK=2
BRAIN_MAX_SUBAGENT_DEPTH=1
BRAIN_MAX_AUTONOMOUS_ITERATIONS=100
# Autonomous stall safety: stop after N consecutive no-progress iterations.
BRAIN_AUTONOMOUS_MAX_CONSECUTIVE_NO_PROGRESS=3
# Per-task action-loop deadline (ms) before GLOBAL_DEADLINE_EXCEEDED blocks further actions.
BRAIN_PER_TURN_DEADLINE_MS=120000

# Shell runtime profile
# Supported profiles: auto, pwsh, powershell, cmd, bash, zsh, wsl_bash.
BRAIN_SHELL_PROFILE=auto
BRAIN_SHELL_TIMEOUT_MS=120000
BRAIN_SHELL_COMMAND_MAX_CHARS=4000
BRAIN_SHELL_ENV_MODE=allowlist
BRAIN_SHELL_ENV_ALLOWLIST=PATH,HOME,USERPROFILE,TEMP,SYSTEMROOT
BRAIN_SHELL_ENV_DENYLIST=TOKEN,SECRET,PASSWORD,AUTH,COOKIE
BRAIN_SHELL_ALLOW_EXECUTION_POLICY_BYPASS=false
BRAIN_SHELL_CWD_POLICY_DENY_OUTSIDE_SANDBOX=false
BRAIN_SHELL_CWD_POLICY_ALLOW_RELATIVE=true

# Profile memory (Agent Friend, Stage 5.5)
BRAIN_PROFILE_MEMORY_ENABLED=false
BRAIN_PROFILE_ENCRYPTION_KEY=<REPLACE_WITH_BASE64_32_BYTE_KEY>
BRAIN_PROFILE_MEMORY_PATH=runtime/profile_memory.secure.json
BRAIN_PROFILE_STALE_AFTER_DAYS=90

# External memory projection (read-only mirror by default)
# Supported sink ids: obsidian, json
# BRAIN_PROJECTION_SINKS=obsidian
# BRAIN_PROJECTION_REALTIME=true
# review_safe redacts sensitive values and assets unless a fuller operator mirror is explicitly allowed.
# BRAIN_PROJECTION_MODE=review_safe
# BRAIN_OBSIDIAN_VAULT_PATH=C:\Users\<you>\Documents\ObsidianVault
# BRAIN_OBSIDIAN_ROOT_DIR=AgentBigBrain
# BRAIN_OBSIDIAN_MIRROR_ASSETS=true
# Optional second sink for seam testing or non-Obsidian inspection:
# BRAIN_JSON_MIRROR_PATH=runtime/projections/json_mirror.json

# Agent Pulse (proactive check-ins)
BRAIN_AGENT_PULSE_ENABLED=false
BRAIN_AGENT_PULSE_TZ_OFFSET_MINUTES=-300
BRAIN_AGENT_PULSE_QUIET_START_HOUR=20
BRAIN_AGENT_PULSE_QUIET_END_HOUR=21
BRAIN_AGENT_PULSE_MIN_INTERVAL_MINUTES=60
BRAIN_AGENT_PULSE_TICK_INTERVAL_MS=10000
BRAIN_ENABLE_DYNAMIC_PULSE=false

# Reflection
BRAIN_REFLECT_ON_SUCCESS=true

# Embeddings (local ONNX vector memory)
# Install local model assets with: npm run setup:embeddings
# Apple Silicon or Rosetta note: if onnxruntime-node fails under darwin/x64 on an M-series Mac,
# use a native arm64 Node install and reinstall dependencies, or set this to false temporarily.
BRAIN_ENABLE_EMBEDDINGS=true
BRAIN_EMBEDDING_MODEL_DIR=models/all-MiniLM-L6-v2
BRAIN_VECTOR_SQLITE_PATH=runtime/vectors.sqlite

# Local conversational interpretation model (optional Ollama-backed Gemma 4 helper)
# Install Ollama, then pull the preferred model with: ollama pull gemma4
# This does not replace the main planner models. It only helps bounded conversational tasks like
# front-door intent, identity interpretation, follow-up disambiguation, and resume/handoff seams.
BRAIN_LOCAL_INTENT_MODEL_ENABLED=false
BRAIN_LOCAL_INTENT_MODEL_PROVIDER=ollama
BRAIN_LOCAL_INTENT_MODEL_BASE_URL=http://127.0.0.1:11434
BRAIN_LOCAL_INTENT_MODEL_NAME=gemma4:latest
BRAIN_LOCAL_INTENT_MODEL_TIMEOUT_MS=45000
# Set this to true on a machine where Gemma 4 is installed if you want the human-centric UX live smoke
# to fail when the real local model was not actually used.
BRAIN_LOCAL_INTENT_MODEL_LIVE_SMOKE_REQUIRED=false

# Ledger persistence
BRAIN_LEDGER_BACKEND=sqlite
BRAIN_LEDGER_SQLITE_PATH=runtime/ledgers.sqlite
BRAIN_LEDGER_EXPORT_JSON_ON_WRITE=true

# Observability (runtime trace)
BRAIN_TRACE_LOG_ENABLED=true
BRAIN_TRACE_LOG_PATH=runtime/runtime_trace.jsonl

# Interface runtime (shared)
TELEGRAM_STREAMING_TRANSPORT_MODE=edit
TELEGRAM_NATIVE_DRAFT_STREAMING=false
BRAIN_INTERFACE_PROVIDER=telegram
# Generate BRAIN_INTERFACE_SHARED_SECRET with a strong random hex string; see docs/SETUP.md.
BRAIN_INTERFACE_SHARED_SECRET=<REPLACE_WITH_RANDOM_HEX_SECRET>
# Use plain usernames without '@'.
# Telegram: message.from.username from getUpdates.
# Discord: your account username (not display name / server nickname).
BRAIN_INTERFACE_ALLOWED_USERNAMES=<comma_separated_usernames>
# Optional stricter allowlist. Most first-time setups can leave this blank.
# Telegram: message.from.id from getUpdates.
# Discord: enable Developer Mode, right-click user, Copy User ID.
BRAIN_INTERFACE_ALLOWED_USER_IDS=<comma_separated_user_ids>
BRAIN_INTERFACE_REQUIRE_NAME_CALL=true
BRAIN_INTERFACE_NAME_ALIASES=BigBrain
BRAIN_INTERFACE_SHOW_TECHNICAL_SUMMARY=false
BRAIN_INTERFACE_SHOW_SAFETY_CODES=false
BRAIN_INTERFACE_SHOW_COMPLETION_PREFIX=false
BRAIN_INTERFACE_RATE_LIMIT_WINDOW_MS=60000
BRAIN_INTERFACE_RATE_LIMIT_MAX_EVENTS=20
BRAIN_INTERFACE_REPLAY_CACHE_SIZE=500
BRAIN_ALLOW_AUTONOMOUS_VIA_INTERFACE=false

# Telegram (required when interface provider includes telegram)
TELEGRAM_BOT_TOKEN=<REPLACE_WITH_TELEGRAM_BOT_TOKEN>
# Optional chat allowlist. Get values from message.chat.id via Telegram getUpdates.
TELEGRAM_ALLOWED_CHAT_IDS=<comma_separated_chat_ids>
TELEGRAM_POLL_TIMEOUT_SECONDS=25
TELEGRAM_POLL_INTERVAL_MS=500

# Discord (required when interface provider includes discord)
DISCORD_BOT_TOKEN=<REPLACE_WITH_DISCORD_BOT_TOKEN>
# Optional channel allowlist. Enable Developer Mode, right-click channel, Copy Channel ID.
DISCORD_ALLOWED_CHANNEL_IDS=<comma_separated_channel_ids>
DISCORD_GATEWAY_INTENTS=37377
